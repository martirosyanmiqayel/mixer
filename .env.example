# Шаблон. Скопируй в .env и впиши свои значения: cp .env.example .env
# НЕ вписывай сюда реальные секреты — этот файл попадает в git.

# ── Discord OAuth (вход на сайт) ─────────────────────────────────
# Developer Portal → приложение → OAuth2 → Client ID и Client Secret
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Боевой адрес (Vercel). Локально можно http://localhost:3000/api/auth/callback
DISCORD_REDIRECT_URI=https://mixergrief.vercel.app/api/auth/callback

# ── Бот, который постит заявки в канал ───────────────────────────
# Developer Portal → приложение → Bot → Reset Token
DISCORD_BOT_TOKEN=
# ID канала (ПКМ по каналу → Копировать ID, нужен режим разработчика)
DISCORD_CHANNEL_ID=

# ── (необязательно) Роль ─────────────────────────────────────────
# ID роли — её пингуют при новой заявке. Пусто = без пинга.
DISCORD_PING_ROLE_ID=

# ── Сервер ───────────────────────────────────────────────────────
PORT=3000
# Длинная случайная строка для подписи cookie-сессий
SESSION_SECRET=change-me-to-a-long-random-string
